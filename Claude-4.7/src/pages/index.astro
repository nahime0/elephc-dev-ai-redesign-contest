---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Positioning from "../components/Positioning.astro";
import Pipeline from "../components/Pipeline.astro";
import Rationale from "../components/Rationale.astro";
import Features from "../components/Features.astro";
import Demo from "../components/Demo.astro";
import GetStarted from "../components/GetStarted.astro";
import Roadmap from "../components/Roadmap.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="elephc — PHP, compiled to native assembly."
  description="elephc is a from-scratch compiler that lowers a static subset of PHP directly to native assembly. No interpreter. No VM. No Zend Engine. 1,800+ tests, 220+ built-ins, 10 data types, 0 runtime deps."
>
  <Nav />
  <main>
    <Hero />
    <Positioning />
    <Pipeline />
    <Rationale />
    <Features />
    <Demo />
    <GetStarted />
    <Roadmap />
  </main>
  <Footer />
</BaseLayout>
