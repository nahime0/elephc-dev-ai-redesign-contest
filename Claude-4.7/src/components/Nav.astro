---

<header class="nav">
  <div class="nav__inner container">
    <a href="#" class="nav__brand" aria-label="elephc — home">
      <span class="nav__mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22">
          <path d="M5 18V6h12" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="square"/>
          <path d="M5 12h9" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="square"/>
          <path d="M5 18h12" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="square"/>
          <circle cx="19" cy="6" r="1.7" fill="#e9a66a"/>
        </svg>
      </span>
      <span class="nav__word">elephc</span>
      <span class="pill nav__pill" aria-label="version 0.19.7"><span class="dot" aria-hidden="true"></span>v0.19.7</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      <a href="#pipeline">Pipeline</a>
      <a href="#features">Features</a>
      <a href="#demo">Demo</a>
      <a href="#start">Install</a>
      <a href="#roadmap">Roadmap</a>
    </nav>

    <div class="nav__cta">
      <a href="#start" class="nav__docs">Docs</a>
      <a class="btn btn-ghost nav__gh" href="https://github.com/illegalstudio/elephc" rel="noopener">
        <svg class="icn" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.88-1.17-.88-1.17-.72-.5.06-.49.06-.49.8.06 1.22.82 1.22.82.71 1.22 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.77-.2-3.64-.89-3.64-3.94 0-.87.31-1.58.82-2.14-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.14 0 3.06-1.87 3.74-3.65 3.93.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"/></svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--bg) 86%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 28px;
    height: 58px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--fg);
  }
  .nav__mark { display: inline-flex; color: var(--fg); }
  .nav__word {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15.5px;
    letter-spacing: -0.02em;
  }
  .nav__pill { margin-left: 6px; }

  .nav__links {
    display: flex;
    justify-content: center;
    gap: 22px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--fg-dim);
    letter-spacing: 0.01em;
  }
  .nav__links a { transition: color 120ms ease; }
  .nav__links a:hover { color: var(--fg); }

  .nav__cta { display: inline-flex; gap: 12px; align-items: center; }
  .nav__docs {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--fg-dim);
    transition: color 120ms ease;
  }
  .nav__docs:hover { color: var(--fg); }

  @media (max-width: 860px) {
    .nav__links { display: none; }
    .nav__inner { grid-template-columns: 1fr auto; }
  }
  @media (max-width: 480px) {
    .nav__pill { display: none; }
    .nav__gh span { display: none; }
    .nav__gh { padding: 9px 11px; }
  }
</style>
