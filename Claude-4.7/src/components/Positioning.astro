---
const items = [
  {
    strike: "a packager",
    title: "Not a packager.",
    body: "elephc does not bundle the Zend Engine, PHP-CLI, or any part of the PHP runtime into your binary. There is no interpreter hiding inside the output.",
  },
  {
    strike: "a transpiler",
    title: "Not a transpiler.",
    body: "It does not emit C, C++, Rust, Go, or any other source language. The pipeline goes straight from PHP to native assembly for your target triple.",
  },
  {
    strike: "a runtime",
    title: "Not a runtime wrapper.",
    body: "There is no opcode cache, no JIT warm-up, no VM to boot. The compiled binary starts in microseconds and links to nothing you didn't ask for.",
  },
];
---

<section class="pos" aria-labelledby="pos-title">
  <div class="container">
    <header class="pos__head">
      <div class="eyebrow">
        <span class="tag">01 / 07</span>
        <span class="sep"></span>
        <span>positioning</span>
      </div>
      <h2 id="pos-title" class="h-section pos__title">
        A compiler, end&#8209;to&#8209;end.<br />
        <span class="mark-dim">The things people call a “PHP compiler” — and elephc isn’t.</span>
      </h2>
    </header>

    <ol class="pos__grid" role="list">
      {items.map((it, i) => (
        <li class="pos__card">
          <div class="pos__idx mono">0{i + 1}</div>
          <div class="pos__strike mono" aria-hidden="true">
            elephc is <span class="mark-strike">{it.strike}</span>
          </div>
          <h3 class="h-sub pos__h">{it.title}</h3>
          <p class="pos__body">{it.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .pos__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: 40px;
    margin-bottom: 64px;
    align-items: end;
  }
  .pos__head .eyebrow { padding-top: 6px; }
  @media (max-width: 900px) {
    .pos__head { grid-template-columns: 1fr; gap: 20px; margin-bottom: 40px; }
  }
  .pos__title { max-width: 22ch; }
  .pos__title .mark-dim { font-weight: 400; color: var(--fg-mute); font-size: 0.54em; display: inline-block; margin-top: 14px; letter-spacing: -0.02em; line-height: 1.35; max-width: 40ch; }

  .pos__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--line-bright);
    border-bottom: 1px solid var(--line-bright);
  }
  @media (max-width: 900px) { .pos__grid { grid-template-columns: 1fr; } }

  .pos__card {
    padding: 32px 28px 36px;
    border-right: 1px solid var(--line);
    display: grid;
    gap: 14px;
    align-content: start;
  }
  .pos__card:last-child { border-right: 0; }

  @media (max-width: 900px) {
    .pos__card { border-right: 0; border-bottom: 1px solid var(--line); }
    .pos__card:last-child { border-bottom: 0; }
  }

  .pos__idx {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .pos__strike {
    font-size: 12px;
    color: var(--fg-mute);
    letter-spacing: 0.01em;
  }
  .pos__h { color: var(--fg); }
  .pos__body {
    color: var(--fg-dim);
    font-size: 15px;
    line-height: 1.65;
  }
</style>
