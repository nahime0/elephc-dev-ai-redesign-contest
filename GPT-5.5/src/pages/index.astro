---
const version = 'v0.19.7';

const asmSnippet = `_main:
    stp     x29, x30, [sp, #-16]!
    mov     x29, sp
    adrp    x0, l_.str.hello@PAGE
    add     x0, x0, l_.str.hello@PAGEOFF
    bl      _puts
    mov     w0, #0`;

const demoSnippet = `for ($x = 0; $x < $screenW; $x++) {
    $ray = cast_ray($player, $x);
    $height = project_wall($ray->distance);
    draw_column($buffer, $x, $height);
}`;

const pipeline = [
	{
		name: 'Parse',
		label: 'source -> AST',
		body: 'PHP tokens become a typed syntax tree. Unsupported dynamic shapes are rejected early instead of being hidden behind a fallback runtime.',
		code: '$ elephc src/raycast.php --emit-ast',
	},
	{
		name: 'Type-check',
		label: 'static subset',
		body: 'Integers, floats, bools, strings, arrays, objects, enums, nullable and union types are resolved before code generation.',
		code: 'types: int|float, array<string,int>, ?Vector',
	},
	{
		name: 'Lower',
		label: 'AST -> native asm',
		body: 'The compiler lowers checked PHP directly into target assembly with optimizer passes for folding, propagation and dead-code elimination.',
		code: '--emit-asm build/raycast.s',
	},
	{
		name: 'Assemble',
		label: 'host toolchain',
		body: 'macOS ARM64, Linux ARM64 and Linux x86_64 targets use the native assembler and linker already present on the system.',
		code: 'as raycast.s -o raycast.o',
	},
	{
		name: 'Link',
		label: 'standalone binary',
		body: 'The result is a standalone executable with elephc runtime routines linked in. No Zend Engine, no VM and no opcode fallback.',
		code: './raycast',
	},
];

const support = [
	['Data types', '10', 'int, float, bool, string, null, arrays, objects, enums, pointers, buffers'],
	['Built-ins', '220+', 'strings, arrays, math, date/time, JSON, regex, I/O, system and type helpers'],
	['Targets', '3', 'macOS ARM64, Linux ARM64, Linux x86_64'],
	['Tests', '1800+', 'compiler, runtime, parser, type-checker, optimizer and codegen coverage'],
];

const roadmap = [
	['current', '0.19.7', 'Switch CFG-lite reachability and guard contradictions in DCE v3'],
	['next', 'libraries', 'Shared/static libraries for compiled PHP modules'],
	['next', 'bridge', 'PHP extension bridge for framework integration'],
	['next', 'optimizer', 'Fixed-point constant propagation and peephole load/store cleanup'],
	['target', '1.0.0', 'Production-ready compiler contract'],
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="elephc is an open-source compiler that lowers a static subset of PHP directly to native assembly for standalone binaries."
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>elephc - PHP to native assembly</title>
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<div class="site-shell">
			<header class="topbar" aria-label="Primary navigation">
				<a class="brand" href="/" aria-label="elephc home">
					<span class="brand-mark" aria-hidden="true">el</span>
					<span>elephc</span>
				</a>
				<nav class="nav-links">
					<a href="#pipeline">Pipeline</a>
					<a href="#support">Support</a>
					<a href="#demo">Demo</a>
					<a href="#start">Start</a>
					<a href="/docs">Docs</a>
				</nav>
				<a class="github-link" href="https://github.com/illegalstudio/elephc" rel="noreferrer">GitHub</a>
			</header>

			<main id="main">
				<section class="hero section-grid" aria-labelledby="hero-title">
					<div class="hero-copy">
						<p class="eyebrow">{version} / optimizer: folding, propagation, DCE</p>
						<h1 id="hero-title">PHP in. Native assembly out.</h1>
						<p class="hero-deck">
							elephc is a from-scratch compiler for a static subset of PHP. It parses,
							type-checks, lowers to native assembly, assembles and links standalone binaries.
						</p>
						<div class="hard-line" role="list" aria-label="Compiler boundaries">
							<span role="listitem">No interpreter</span>
							<span role="listitem">No VM</span>
							<span role="listitem">No Zend fallback</span>
						</div>
						<div class="hero-actions">
							<a class="button primary" href="#start">Compile tonight</a>
							<a class="button secondary" href="https://github.com/illegalstudio/elephc" rel="noreferrer">Read the source</a>
						</div>
					</div>

					<div class="compile-board" aria-label="Compilation example">
						<div class="window-bar">
							<span></span><span></span><span></span>
							<strong>native build transcript</strong>
						</div>
						<div class="terminal-lines">
							<p><span class="prompt">$</span> elephc hello.php --emit-asm</p>
							<p class="muted">parse <span>ok</span> / type-check <span>ok</span> / lower <span>arm64</span></p>
							<p><span class="prompt">$</span> sed -n '1,7p' hello.s</p>
							<pre><code>{asmSnippet}</code></pre>
							<p><span class="prompt">$</span> ./hello</p>
							<p class="stdout">Hello, World!</p>
						</div>
					</div>
				</section>

				<section class="proof-strip" aria-label="Project proof points">
					{
						support.map(([name, value, detail]) => (
							<article>
								<strong>{value}</strong>
								<span>{name}</span>
								<p>{detail}</p>
							</article>
						))
					}
				</section>

				<section class="positioning section-grid">
					<div>
						<p class="eyebrow">Positioning</p>
						<h2>A compiler for PHP, not a PHP wrapper.</h2>
					</div>
					<div class="position-cards">
						<article>
							<h3>Compiler model</h3>
							<p>
								elephc does not bundle PHP. Supported source is compiled ahead of time into
								native output, with a small runtime linked into the binary.
							</p>
						</article>
						<article>
							<h3>Runtime contract</h3>
							<p>
								If elephc compiles it, it runs as native code. Unsupported dynamic behavior is
								a boundary the compiler reports, not a slow path it hides.
							</p>
						</article>
						<article>
							<h3>Framework direction</h3>
							<p>
								The long-term path is hybrid: keep Laravel, Symfony, WordPress or custom PHP
								apps, then compile static hot-path modules into native libraries or extensions.
							</p>
						</article>
					</div>
				</section>

				<section id="pipeline" class="pipeline-section" aria-labelledby="pipeline-title">
					<div class="section-heading">
						<p class="eyebrow">How it works</p>
						<h2 id="pipeline-title">A visible pipeline, not a magic box.</h2>
						<p>
							The home page should teach the important part: elephc has real compiler stages
							and each one draws a line around what the language subset can promise.
						</p>
					</div>

					<div class="pipeline-rail" aria-label="Compiler pipeline">
						{
								pipeline.map((stage, index) => (
									<article class="stage-card">
									<span class="stage-index">0{index + 1}</span>
									<h3>{stage.name}</h3>
									<p class="stage-label">{stage.label}</p>
									<p>{stage.body}</p>
									<code>{stage.code}</code>
								</article>
							))
						}
					</div>
				</section>

				<section id="support" class="support-section section-grid" aria-labelledby="support-title">
					<div class="support-copy">
						<p class="eyebrow">Supported surface</p>
						<h2 id="support-title">The subset is the point.</h2>
						<p>
							PHP is dynamic by default. elephc narrows the contract so a compiler can make
							hard promises: static types, explicit boundaries, direct native code and failure
							when source escapes the model.
						</p>
						<ul class="check-list">
							<li>Classes, constructors, methods, traits, inheritance, interfaces and abstract classes</li>
							<li>Closures, captures, IIFEs, variadics, spread, named arguments and enums</li>
							<li>Arrays, associative arrays, nullables, unions, exceptions and copy-on-write strings</li>
							<li>FFI, pointers, packed classes, buffer&lt;T&gt; and low-level memory access</li>
						</ul>
					</div>

					<div class="matrix" aria-label="Platform support matrix">
						<div class="matrix-row matrix-head">
							<span>Target</span>
							<span>Output</span>
							<span>Status</span>
						</div>
						<div class="matrix-row">
							<span>macOS ARM64</span>
							<span>Mach-O binary</span>
							<strong>shipping</strong>
						</div>
						<div class="matrix-row">
							<span>Linux ARM64</span>
							<span>ELF binary</span>
							<strong>shipping</strong>
						</div>
						<div class="matrix-row">
							<span>Linux x86_64</span>
							<span>ELF binary</span>
							<strong>shipping</strong>
						</div>
						<div class="matrix-row future">
							<span>Shared/static libs</span>
							<span>.a / .so / .dylib</span>
							<strong>next</strong>
						</div>
						<div class="matrix-row future">
							<span>PHP extension bridge</span>
							<span>native module</span>
							<strong>next</strong>
						</div>
					</div>
				</section>

				<section id="demo" class="demo-section" aria-labelledby="demo-title">
					<div class="section-heading">
						<p class="eyebrow">Proof artifact</p>
						<h2 id="demo-title">A Doom-style engine is a better claim than a slogan.</h2>
						<p>
							The current site uses a PHP-written, elephc-compiled 3D engine as the credibility
							check. This redesign keeps it central: arrays, math, loops and rendering pressure
							show the compiler doing work that toy examples cannot.
						</p>
					</div>

					<div class="demo-frame">
						<div class="viewport" aria-label="Stylized Doom-style 3D engine preview">
							<div class="sky"></div>
							<div class="wall wall-a"></div>
							<div class="wall wall-b"></div>
							<div class="wall wall-c"></div>
							<div class="floor-grid"></div>
							<div class="hud">
								<span>php/raycast.php</span>
								<span>native binary</span>
								<span>60 hz loop*</span>
							</div>
						</div>
						<div class="demo-side">
							<h3>Compiled PHP doing engine work</h3>
							<p>
								The demo is the right kind of weird: recognizably PHP, but pushed through a
								compiler pipeline until it behaves like a native program.
							</p>
							<pre><code>{demoSnippet}</code></pre>
							<p class="caption">*The visual shown here is a CSS recreation of the live-site proof, not a benchmark claim.</p>
						</div>
					</div>
				</section>

				<section id="start" class="start-section section-grid" aria-labelledby="start-title">
					<div>
						<p class="eyebrow">Get started</p>
						<h2 id="start-title">Install the compiler. Build one file.</h2>
						<p>
							You need Rust if building from source, plus the native assembler and linker for
							your host. On macOS that means Xcode Command Line Tools or Homebrew; on Linux,
							the standard `as`, `ld` and libc development files.
						</p>
					</div>
					<div class="install-card">
						<div class="tabs" aria-label="Install options">
							<span>Homebrew</span>
							<span>Source</span>
							<span>Verify</span>
						</div>
						<pre><code># Homebrew
$ brew install illegalstudio/tap/elephc

# Or build from source
$ git clone https://github.com/illegalstudio/elephc.git
$ cd elephc &amp;&amp; cargo build --release

# Compile and run
$ elephc hello.php
$ ./hello
Hello, World!

# Compiler test suite
$ cargo test
# 1800+ tests, all passing</code></pre>
					</div>
				</section>

				<section class="structure-section" aria-labelledby="structure-title">
					<div class="section-heading">
						<p class="eyebrow">Repository map</p>
						<h2 id="structure-title">The source tree reads like a compiler.</h2>
					</div>
					<div class="tree-card">
						<pre><code>src/
  main.rs        CLI entry point
  lexer/         source -> tokens
  parser/        tokens -> AST
  types/         static type checking
  codegen/       AST -> native asm
  builtins/      strings / arrays / math / types / io / system
  runtime/       strings / arrays / exceptions / io / system
  errors/        line:col diagnostics</code></pre>
						<p>
							The directory names are part of the pitch. This is not a packaging trick; it is
							a Rust compiler with parser, type system, code generator and target runtime.
						</p>
					</div>
				</section>

				<section class="roadmap-section section-grid" aria-labelledby="roadmap-title">
					<div>
						<p class="eyebrow">Roadmap snapshot</p>
						<h2 id="roadmap-title">Honest status toward 1.0.</h2>
						<p>
							v0.19.x is optimizer-heavy: constant folding, local propagation, effect analysis,
							control-flow normalization and path-aware dead-code elimination. The next public
							milestones are about integration and production hardening.
						</p>
					</div>
					<div class="roadmap-list">
						{
							roadmap.map(([kind, label, text]) => (
								<article>
									<span>{kind}</span>
									<strong>{label}</strong>
									<p>{text}</p>
								</article>
							))
						}
					</div>
				</section>

				<section class="faq-section" aria-labelledby="faq-title">
					<p class="eyebrow">Skeptical questions</p>
					<h2 id="faq-title">The answers should be crisp.</h2>
					<div class="faq-grid">
						<article>
							<h3>Is this a PHP packager?</h3>
							<p>No. elephc does not ship Zend/PHP inside the result. It compiles supported PHP to native assembly and links a small runtime.</p>
						</article>
						<article>
							<h3>Can it replace a whole framework?</h3>
							<p>Not today. The pragmatic route is to keep the framework and compile static, performance-sensitive modules first.</p>
						</article>
						<article>
							<h3>What happens to unsupported PHP?</h3>
							<p>It should fail at the compiler boundary. Silent fallback would make performance and semantics impossible to trust.</p>
						</article>
					</div>
				</section>
			</main>

			<footer class="footer">
				<div>
					<a class="brand" href="/">
						<span class="brand-mark" aria-hidden="true">el</span>
						<span>elephc</span>
					</a>
					<p>
						Open-source PHP-to-native-assembly compiler for macOS ARM64, Linux ARM64 and Linux x86_64.
						Written in Rust. MIT licensed.
					</p>
				</div>
				<nav aria-label="Footer navigation">
					<a href="https://github.com/illegalstudio/elephc" rel="noreferrer">GitHub</a>
					<a href="/docs">Documentation</a>
					<a href="#start">Installation</a>
					<a href="https://illegal.studio" rel="noreferrer">Illegal Studio</a>
				</nav>
				<p class="license">{version} / MIT License / 2026</p>
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		--bg: #090b0a;
		--panel: #101410;
		--panel-2: #151a14;
		--ink: #f4f0df;
		--muted: #aaa690;
		--dim: #6f735f;
		--line: rgba(244, 240, 223, 0.15);
		--line-strong: rgba(244, 240, 223, 0.28);
		--acid: #c9ff4a;
		--amber: #ffb454;
		--rust: #e16134;
		--green: #62d487;
		--mono: "SFMono-Regular", "Cascadia Code", "Liberation Mono", "Fira Code", monospace;
		--serif: "Iowan Old Style", "Palatino Linotype", "URW Palladio L", Georgia, serif;
		--sans: "Avenir Next", "Segoe UI", "Helvetica Neue", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--bg);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		background:
			linear-gradient(90deg, rgba(201, 255, 74, 0.035) 1px, transparent 1px) 0 0 / 64px 64px,
			linear-gradient(rgba(201, 255, 74, 0.025) 1px, transparent 1px) 0 0 / 64px 64px,
			radial-gradient(circle at 75% 5%, rgba(225, 97, 52, 0.24), transparent 34rem),
			radial-gradient(circle at 8% 22%, rgba(98, 212, 135, 0.12), transparent 28rem),
			var(--bg);
		color: var(--ink);
		font-family: var(--sans);
		line-height: 1.5;
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		content: "";
		background:
			linear-gradient(rgba(255, 255, 255, 0.025) 50%, transparent 50%) 0 0 / 100% 4px,
			radial-gradient(circle at center, transparent 0, rgba(0, 0, 0, 0.74) 82%);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	p,
	h1,
	h2,
	h3,
	pre {
		margin: 0;
	}

	code,
	pre {
		font-family: var(--mono);
	}

	pre {
		overflow-x: auto;
		white-space: pre;
	}

	.skip-link {
		position: fixed;
		left: 1rem;
		top: 1rem;
		z-index: 10;
		transform: translateY(-150%);
		background: var(--acid);
		color: #101410;
		padding: 0.6rem 0.8rem;
		border-radius: 999px;
		font-weight: 800;
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	.site-shell {
		width: min(100%, 1640px);
		margin: 0 auto;
		padding: 1rem clamp(1rem, 2vw, 2rem) 2rem;
	}

	.topbar {
		position: sticky;
		top: 1rem;
		z-index: 5;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.65rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(9, 11, 10, 0.82);
		backdrop-filter: blur(18px);
		box-shadow: 0 20px 70px rgba(0, 0, 0, 0.26);
	}

	.brand,
	.github-link,
	.nav-links a,
	.button {
		min-height: 44px;
		display: inline-flex;
		align-items: center;
	}

	.brand {
		gap: 0.65rem;
		padding: 0 0.8rem 0 0.15rem;
		font-family: var(--mono);
		font-weight: 800;
		letter-spacing: -0.04em;
	}

	.brand-mark {
		display: grid;
		width: 2.25rem;
		height: 2.25rem;
		place-items: center;
		border: 1px solid rgba(201, 255, 74, 0.5);
		border-radius: 50%;
		background: #d8ff59;
		color: #101410;
		font-size: 0.76rem;
		text-transform: uppercase;
	}

	.nav-links {
		display: flex;
		justify-content: center;
		gap: clamp(0.1rem, 1.4vw, 1rem);
		color: var(--muted);
		font: 700 0.76rem/1 var(--mono);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.nav-links a,
	.github-link {
		border-radius: 999px;
		padding: 0 0.8rem;
	}

	.nav-links a:hover,
	.nav-links a:focus-visible,
	.github-link:hover,
	.github-link:focus-visible {
		background: rgba(244, 240, 223, 0.08);
		color: var(--ink);
		outline: none;
	}

	.github-link {
		justify-self: end;
		background: rgba(244, 240, 223, 0.08);
		color: var(--ink);
		font: 800 0.8rem/1 var(--mono);
		text-transform: uppercase;
	}

	main {
		display: grid;
		gap: clamp(4rem, 9vw, 8rem);
	}

	.section-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: start;
	}

	.hero {
		min-height: calc(100vh - 5rem);
		padding: clamp(3rem, 8vw, 7rem) 0 1rem;
		align-items: center;
	}

	.eyebrow {
		color: var(--acid);
		font: 800 0.76rem/1.2 var(--mono);
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	h1,
	h2 {
		max-width: 13ch;
		font-family: var(--serif);
		font-weight: 800;
		letter-spacing: -0.075em;
		line-height: 0.92;
	}

	h1 {
		margin-top: 1rem;
		font-size: clamp(4.8rem, 13vw, 13.5rem);
	}

	h2 {
		margin-top: 0.85rem;
		font-size: clamp(3.2rem, 7vw, 8rem);
	}

	h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.hero-deck,
	.section-heading p,
	.support-copy > p,
	.start-section > div > p,
	.roadmap-section > div > p,
	.footer p {
		max-width: 66ch;
		color: var(--muted);
		font-size: clamp(1rem, 1.45vw, 1.3rem);
	}

	.hero-deck {
		margin-top: 1.35rem;
	}

	.hard-line {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 1.4rem;
	}

	.hard-line span {
		border: 1px solid rgba(255, 180, 84, 0.38);
		border-radius: 999px;
		padding: 0.42rem 0.7rem;
		color: #ffd39c;
		font: 800 0.78rem/1 var(--mono);
		text-transform: uppercase;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.button {
		border: 1px solid var(--line-strong);
		border-radius: 999px;
		padding: 0 1.1rem;
		font: 900 0.82rem/1 var(--mono);
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.button.primary {
		border-color: rgba(201, 255, 74, 0.75);
		background: var(--acid);
		color: #101410;
		box-shadow: 0 0 36px rgba(201, 255, 74, 0.22);
	}

	.button.secondary {
		background: rgba(244, 240, 223, 0.06);
	}

	.button:hover,
	.button:focus-visible {
		transform: translateY(-2px);
		outline: none;
	}

	.compile-board,
	.install-card,
	.tree-card,
	.matrix,
